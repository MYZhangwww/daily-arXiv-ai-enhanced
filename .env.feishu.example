# Feishu 通知配置示例 / Feishu Notification Configuration Example

# 飞书机器人 Webhook URL
# 格式: https://open.feishu.cn/open-apis/bot/v2/hook/{HOOK_ID}
# 从飞书群组的机器人设置中获取
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id-here

# 飞书机器人密钥（用于签名校验）
# 从飞书群组的机器人设置中获取（勾选"加签"后可获得）
# 如不设置签名校验，可留空或删除此行
FEISHU_SECRET=your-secret-here

# 飞书通知开关（可选）
# 值: true/false，默认如果设置了 FEISHU_WEBHOOK_URL 则启用
# FEISHU_ENABLED=true
